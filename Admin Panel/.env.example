APP_NAME="Plantix AI"
APP_ENV=local
APP_KEY=
# IMPORTANT: Set APP_DEBUG=false and APP_ENV=production before deploying!
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=plantix_ai
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
# Use 'database' queue in production so jobs are persisted and retried.
# Run: php artisan queue:table && php artisan migrate
# Start worker: php artisan queue:work --queue=disease-detection,default
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@plantix.ai"
MAIL_FROM_NAME="${APP_NAME}"

# Stripe (card payments)
STRIPE_KEY=
STRIPE_SECRET=
# Obtain from Stripe Dashboard → Webhooks → signing secret
STRIPE_WEBHOOK_SECRET=

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000

# Plantix system config
PLANTIX_TAX_RATE=0.0
PLANTIX_CURRENCY_CODE=PKR
PLANTIX_CURRENCY_SYMBOL=Rs
PLANTIX_LOW_STOCK_THRESHOLD=10
PLANTIX_CART_MAX_ITEMS=50
PLANTIX_FEATURED_COUNT=8
PLANTIX_APPOINTMENTS_PER_DAY=10
# Days after delivery that customer may submit a return request
PLANTIX_RETURN_WINDOW_DAYS=7
MANUAL_PAYMENT_ENABLED=false

# AI & External APIs (required features)
OPENWEATHER_API_KEY=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
AI_CHAT_MAX_HISTORY=10

# Disease detection — points to the Flask crop_prediction_api (VGG16 model)
# The Flask API serves POST /disease/predict for image-based disease detection
DISEASE_API_URL=http://127.0.0.1:5000
DISEASE_API_KEY=

# Flask crop prediction API
CROP_PREDICTION_API_URL=http://127.0.0.1:5000
CROP_PREDICTION_API_KEY=
CROP_PREDICTION_API_TIMEOUT=8

# Flask fertilizer recommendation API (defaults can point to same service)
FERTILIZER_PREDICTION_API_URL=http://127.0.0.1:5000
FERTILIZER_PREDICTION_API_KEY=
FERTILIZER_PREDICTION_API_TIMEOUT=8

# ─── OpenRouter AI (https://openrouter.ai) ──────────────────────────────────
# Used for AI-powered crop planning via LLM
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-27b-it:free
OPENROUTER_TIMEOUT=30
