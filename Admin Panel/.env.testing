MAIL_MAILER=array

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000

PLANTIX_TAX_RATE=0.0
PLANTIX_CURRENCY_CODE=PKR
PLANTIX_CURRENCY_SYMBOL=Rs
