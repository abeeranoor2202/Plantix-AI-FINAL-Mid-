FLASK_ENV=production
APP_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
API_KEY=replace-with-a-long-random-api-key
API_KEY_HEADER=X-API-Key
MODEL_NAME=crop_recommendation_model
MODEL_VERSION=1.0.0
MODEL_PATH=./model/RandomForest.pkl
FERTILIZER_MODEL_NAME=fertilizer_recommendation_model
FERTILIZER_MODEL_VERSION=1.0.0
FERTILIZER_MODEL_PATH=./model/fertilizer.pkl
DISEASE_MODEL_PATH=./model/vgg16Mymodel.h5
DATABASE_PATH=./instance/predictions.sqlite3
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
RATELIMIT_DEFAULT=120 per minute
RATELIMIT_STORAGE_URI=memory://
MAX_CONTENT_LENGTH=1048576
