{
  "info": {
    "name": "Crop Prediction API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Model Info",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/model-info"
      }
    },
    {
      "name": "Predict",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{api_key}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nitrogen\": 90,\n  \"phosphorus\": 42,\n  \"potassium\": 43,\n  \"temperature\": 22.5,\n  \"humidity\": 82,\n  \"ph\": 6.5,\n  \"rainfall\": 200\n}"
        },
        "url": "{{base_url}}/predict"
      }
    },
    {
      "name": "Admin Predictions",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{api_key}}" }
        ],
        "url": "{{base_url}}/admin/predictions?limit=25&offset=0"
      }
    },
    {
      "name": "Admin Stats",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{api_key}}" }
        ],
        "url": "{{base_url}}/admin/stats"
      }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000" },
    { "key": "api_key", "value": "replace-with-a-long-random-api-key" }
  ]
}